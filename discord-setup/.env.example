# Copy this file to .env, then fill in your real values.
# Never commit the real .env file.

DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# Optional training info used in the pinned training-call-info message.
TRAINING_DATE=Saturday, July 18, 2026
TRAINING_TIME=3:00 PM Central
TRAINING_LINK=

# Existing channels and roles are reused. Existing channels are not deleted.
SYNC_EXISTING_PERMISSIONS=true
CREATE_PINNED_MESSAGES=true

